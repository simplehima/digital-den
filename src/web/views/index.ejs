<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>The Digital Den</title>
    <style>
        body {
            background-color: #0f0f13;
            color: #ffffff;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100vh;
            margin: 0;
            background-image: url('/background.png'); /* Use the bot welcome bg as site bg too */
            background-size: cover;
            background-blend-mode: overlay;
        }
        .container {
            background: rgba(0, 0, 0, 0.8);
            padding: 40px;
            border-radius: 15px;
            text-align: center;
            box-shadow: 0 0 20px #8a2be2;
        }
        h1 { margin-bottom: 10px; color: #b19cd9; }
        p { margin-bottom: 30px; font-size: 1.2rem; }
        .btn {
            background: #5865F2;
            color: white;
            padding: 15px 30px;
            text-decoration: none;
            border-radius: 5px;
            font-weight: bold;
            transition: background 0.3s;
        }
        .btn:hover { background: #4752C4; }
    </style>
</head>
<body>
    <div class="container">
        <h1>Welcome to The Digital Den</h1>
        <p>The high-tech sanctuary for gamers and creators.</p>
        <% if (user) { %>
            <p>Hello, <%= user.username %>!</p>
            <a href="/dashboard" class="btn">Go to Dashboard</a>
            <br><br>
            <a href="/auth/logout" style="color: #bbb;">Logout</a>
        <% } else { %>
            <a href="/auth/login" class="btn">Login with Discord</a>
        <% } %>
    </div>
</body>
</html>
