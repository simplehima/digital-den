DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_client_id_here
PORT=3000

# YouTube Cookie Support (choose ONE method below)

# Method 1: Use browser cookies (recommended - easy setup)
# Uncomment ONE of these based on your browser:
# COOKIES_FROM_BROWSER=chrome
# COOKIES_FROM_BROWSER=firefox
# COOKIES_FROM_BROWSER=edge
# COOKIES_FROM_BROWSER=safari

# Method 2: Use cookies.txt file
# 1. Export cookies using a browser extension
# 2. Place cookies.txt in the root directory
# 3. Uncomment the line below:
# COOKIES_FILE=./cookies.txt
